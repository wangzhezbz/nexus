# 中央认证 auth-service 环境变量
# 关键：JWT_SECRET 必须与 api-relay 后端（及其它接入 SSO 的产品）完全一致，
# 否则各产品验不过中央签发的 cookie → 单点登录失效。
JWT_SECRET=change_me_strong_shared_secret_same_as_relay
JWT_TTL_SECONDS=604800

DATABASE_URL=mysql+pymysql://user:pass@mysql:3306/authdb
# 本地开发可用 sqlite：sqlite:///auth_dev.db

# 生产（HTTPS + 单域名）：COOKIE_SECURE=1，COOKIE_DOMAIN 留空即可（同域 host-only）
# 若多子域共享登录，COOKIE_DOMAIN=.shanhaiyouling.com
COOKIE_SECURE=1
COOKIE_DOMAIN=

# 允许携带 cookie 的来源（单域名部署填站点根）
CORS_ORIGINS=https://shanhaiyouling.com
